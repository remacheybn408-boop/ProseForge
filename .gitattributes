# Auto-detect text files
* text=auto

# Normalize line endings for source files
*.py text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.sql text eol=lf

# Windows batch stays CRLF
*.bat text eol=crlf

# Evaluation fixtures hash raw bytes; never convert line endings
tests/evaluation/fixtures/*.txt text eol=lf
