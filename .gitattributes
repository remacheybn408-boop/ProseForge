# Auto-detect text files, normalize to LF
* text=auto

# Source code: force LF
*.py text eol=lf
*.sql text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.sh text eol=lf

# Binary
*.db binary
*.sqlite binary
*.png binary
*.jpg binary
*.mp3 binary
