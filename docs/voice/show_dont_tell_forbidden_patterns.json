{
  "version": "v0.3.1-qgp",
  "description": "AI 总结句 / 空泛句 / 说教句禁用模式——检测章节中不应出现的 AI 腔句式",
  "severity": "WARNING",
  "patterns": {
    "summary_realization": {
      "description": "总结性顿悟——用一句总结代替叙事推进",
      "regex": [
        "他终于明白",
        "她终于意识到",
        "他终于懂了",
        "她终于看透",
        "他终于醒悟",
        "她终于想通",
        "他终于理解",
        "她终于知道",
        "那一刻.{1,10}(终于|突然|忽然).{1,10}(明白|意识到|懂了|知道了)"
      ]
    },
    "empty_crisis": {
      "description": "空泛危机句——用模糊危机代替具体钩子",
      "regex": [
        "真正的危机才刚刚开始",
        "真正的风暴即将来临",
        "更大的阴谋正在靠近",
        "真正的考验才刚开始",
        "没人知道等待.{1,10}的是什么",
        "更大的危险正在酝酿",
        "暗流涌动",
        "风雨欲来"
      ]
    },
    "fate_cliche": {
      "description": "命运齿轮类——用宿命论代替剧情推进",
      "regex": [
        "命运的齿轮开始转动",
        "命运.{0,5}的齿轮",
        "命运的轨迹",
        "命运的捉弄",
        "宿命的安排",
        "一切都是命中注定",
        "这就是他的命",
        "这就是她的命"
      ]
    },
    "vague_relationship": {
      "description": "空泛关系变化——不写具体互动，写抽象总结",
      "regex": [
        "关系发生了微妙的变化",
        "关系变得不同了",
        "从此再也不一样了",
        "某种说不清的东西在他们之间",
        "关系悄然改变",
        "无形的隔阂",
        "若有若无的距离",
        "前所未有的.{1,5}感"
      ]
    },
    "empty_emotion": {
      "description": "空泛情绪——用抽象情绪词代替动作表现",
      "regex": [
        "前所未有的恐惧",
        "无法描述的恐惧",
        "说不出的恐惧",
        "复杂的情绪",
        "无法言说的情绪",
        "五味杂陈",
        "百感交集",
        "一种难以名状的感觉"
      ]
    },
    "telescope_sentence": {
      "description": "望远镜句——俯瞰式总结未来",
      "regex": [
        "多年以后.{0,20}回想起",
        "他那时还不知道",
        "她那时还不知道",
        "那时的他们还不知道",
        "很久以后.{0,10}才会明白",
        "很多年以后",
        "这将是.{0,10}最后一次"
      ]
    },
    "lecture_voice": {
      "description": "说教腔——用旁白给读者上课",
      "regex": [
        "要知道.{0,10}从来都不是",
        "说到底.{0,10}不过是",
        "人生就是这样",
        "这就是修仙界的残酷",
        "在这个弱肉强食的世界",
        "这就是修仙",
        "修行的本质",
        "真正的强者"
      ]
    }
  },
  "exemptions": {
    "description": "以下情况不触发检测",
    "rules": [
      "角色对白中的内容（在引号内的）",
      "角色内心独白中的自我判断（需标记）",
      "已在前文建立伏笔的回响句式"
    ]
  },
  "check_scope": {
    "description": "检测范围",
    "target": "旁白和叙述文本（排除对白引号内内容）",
    "min_chapter_chars": 500,
    "max_matches_before_warning": 2,
    "max_matches_before_fail": 5
  }
}
